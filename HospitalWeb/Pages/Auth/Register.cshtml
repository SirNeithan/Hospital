@page
@model HospitalWeb.Pages.Auth.RegisterModel
@using HospitalManagement.Core.Models
@{ Layout = null; ViewData["Title"] = "Register"; }

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register – City Hospital</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <style>
        body { background: linear-gradient(135deg, #0f4c81 0%, #1a7a5e 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; font-family: 'Segoe UI', sans-serif; padding: 2rem 1rem; }
        .auth-card { background: #fff; border-radius: 16px; box-shadow: 0 20px 60px rgba(0,0,0,.25); width: 100%; max-width: 680px; overflow: hidden; }
        .auth-header { background: linear-gradient(135deg, #0f4c81, #1a7a5e); padding: 1.75rem; text-align: center; color: #fff; }
        .auth-header .hospital-icon { font-size: 2.5rem; margin-bottom: .4rem; }
        .auth-header h1 { font-size: 1.4rem; font-weight: 700; margin: 0; }
        .auth-header p { font-size: .82rem; opacity: .85; margin: .2rem 0 0; }
        .auth-body { padding: 2rem; }
        .section-title { font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; color: #0f4c81; border-bottom: 2px solid #e5e7eb; padding-bottom: .4rem; margin-bottom: 1rem; }
        .form-label { font-weight: 600; font-size: .875rem; color: #374151; }
        .form-control, .form-select { border-radius: 8px; border: 1.5px solid #d1d5db; padding: .55rem .9rem; font-size: .9rem; }
        .form-control:focus, .form-select:focus { border-color: #0f4c81; box-shadow: 0 0 0 3px rgba(15,76,129,.15); }
        .btn-register { background: linear-gradient(135deg, #0f4c81, #1a7a5e); border: none; border-radius: 8px; padding: .75rem; font-weight: 600; color: #fff; width: 100%; }
        .btn-register:hover { opacity: .9; color: #fff; }
        .login-link { text-align: center; font-size: .875rem; color: #6b7280; margin-top: 1rem; }
        .login-link a { color: #0f4c81; font-weight: 600; text-decoration: none; }
        .alert-error { background: #fef2f2; border: 1px solid #fecaca; color: #dc2626; border-radius: 8px; padding: .75rem 1rem; font-size: .875rem; }
    </style>
</head>
<body>
<div class="auth-card">
    <div class="auth-header">
        <div class="hospital-icon"><i class="fa-solid fa-hospital"></i></div>
        <h1>Patient Registration</h1>
        <p>City Hospital – Create your patient account</p>
    </div>
    <div class="auth-body">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert-error mb-3">
                <i class="fa-solid fa-circle-exclamation me-2"></i>@Model.ErrorMessage
            </div>
        }

        <form method="post">
            <!-- Account credentials -->
            <div class="section-title"><i class="fa-solid fa-key me-2"></i>Account Credentials</div>
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="form-label">Username *</label>
                    <input asp-for="Username" class="form-control" placeholder="e.g. john.doe" />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Password *</label>
                    <input asp-for="Password" class="form-control" placeholder="Min 6 characters" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Confirm Password *</label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>

            <!-- Personal information -->
            <div class="section-title"><i class="fa-solid fa-user me-2"></i>Personal Information</div>
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="form-label">First Name *</label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Last Name *</label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Date of Birth *</label>
                    <input asp-for="DateOfBirth" type="date" class="form-control" />
                    <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Gender</label>
                    <select asp-for="Gender" asp-items="Html.GetEnumSelectList<Gender>()" class="form-select"></select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Blood Type</label>
                    <select asp-for="BloodType" asp-items="Html.GetEnumSelectList<BloodType>()" class="form-select"></select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Phone Number *</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="+256 7XX XXX XXX" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="your@email.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Address</label>
                    <input asp-for="Address" class="form-control" placeholder="Your home address" />
                </div>
            </div>

            <!-- Emergency contact -->
            <div class="section-title"><i class="fa-solid fa-phone-volume me-2"></i>Emergency Contact</div>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label">Contact Name *</label>
                    <input asp-for="EmergencyContactName" class="form-control" placeholder="Full name" />
                    <span asp-validation-for="EmergencyContactName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Contact Phone *</label>
                    <input asp-for="EmergencyContactPhone" class="form-control" placeholder="+256 7XX XXX XXX" />
                    <span asp-validation-for="EmergencyContactPhone" class="text-danger small"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-register">
                <i class="fa-solid fa-user-plus me-2"></i>Create My Account
            </button>
        </form>
        <div class="login-link">
            Already have an account? <a href="/Auth/Login">Sign in here</a>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.21.0/dist/jquery.validate.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
