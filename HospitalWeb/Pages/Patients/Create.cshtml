@page
@model HospitalWeb.Pages.Patients.CreateModel
@{ ViewData["Title"] = "Register Patient"; ViewData["Page"] = "Patients"; }

<div class="page-header">
    <h2><i class="fa-solid fa-user-plus me-2"></i>Register New Patient</h2>
    <a href="/Patients" class="btn btn-outline-secondary btn-sm">← Back</a>
</div>

<div class="card" style="max-width:760px">
    <div class="card-body">
        <form method="post">
            <div class="form-section-title">Personal Information</div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">First Name *</label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Last Name *</label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Date of Birth *</label>
                    <input asp-for="DateOfBirth" type="date" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Gender</label>
                    <select asp-for="Gender" asp-items="Html.GetEnumSelectList<HospitalManagement.Core.Models.Gender>()" class="form-select"></select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Blood Type</label>
                    <select asp-for="BloodType" asp-items="Html.GetEnumSelectList<HospitalManagement.Core.Models.BloodType>()" class="form-select"></select>
                </div>
            </div>

            <div class="form-section-title">Contact Details</div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">Phone Number *</label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" type="email" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">Address</label>
                    <input asp-for="Address" class="form-control" />
                </div>
            </div>

            <div class="form-section-title">Emergency Contact</div>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label">Contact Name *</label>
                    <input asp-for="EmergencyContactName" class="form-control" />
                    <span asp-validation-for="EmergencyContactName" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Contact Phone *</label>
                    <input asp-for="EmergencyContactPhone" class="form-control" />
                    <span asp-validation-for="EmergencyContactPhone" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Register Patient</button>
                <a href="/Patients" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
