@page
@model HospitalWeb.Pages.Billing.PayModel
@{ ViewData["Title"] = "Record Payment"; ViewData["Page"] = "Billing"; }

<div class="page-header">
    <h2><i class="fa-solid fa-money-bill-wave me-2"></i>Record Payment</h2>
    <a href="/Billing/Details?id=@Model.Bill?.Id" class="btn btn-outline-secondary btn-sm">← Back</a>
</div>

@if (Model.ErrorMessage != null) { <div class="alert alert-danger">@Model.ErrorMessage</div> }

<div class="card" style="max-width:480px">
    <div class="card-body">
        <table class="table table-sm table-borderless mb-4">
            <tr><td class="text-muted">Patient</td><td class="fw-semibold">@Model.Bill?.PatientName</td></tr>
            <tr><td class="text-muted">Bill Total</td><td>UGX @Model.Bill?.TotalAmount.ToString("N2")</td></tr>
            <tr><td class="text-muted">Amount Paid</td><td class="text-success">UGX @Model.Bill?.AmountPaid.ToString("N2")</td></tr>
            <tr><td class="text-muted">Balance Due</td><td class="fw-bold text-warning">UGX @Model.Bill?.Balance.ToString("N2")</td></tr>
        </table>

        <form method="post" asp-route-id="@Model.Bill?.Id">
            <div class="mb-4">
                <label class="form-label">Payment Amount ($) *</label>
                <input asp-for="Amount" type="number" step="0.01" class="form-control form-control-lg" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Confirm Payment</button>
                <a href="/Billing/Details?id=@Model.Bill?.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
