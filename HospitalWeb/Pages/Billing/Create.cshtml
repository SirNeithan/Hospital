@page
@model HospitalWeb.Pages.Billing.CreateModel
@{ ViewData["Title"] = "Generate Bill"; ViewData["Page"] = "Billing"; }

<div class="page-header">
    <h2><i class="fa-solid fa-receipt me-2"></i>Generate Bill</h2>
    <a href="/Billing" class="btn btn-outline-secondary btn-sm">← Back</a>
</div>

<div class="card" style="max-width:820px">
    <div class="card-body">
        <form method="post" id="billForm">
            <input type="hidden" asp-for="ItemsJson" id="itemsJson" />

            <div class="form-section-title">Patient & Insurance</div>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label class="form-label">Patient *</label>
                    <select asp-for="PatientId" class="form-select">
                        <option value="0">-- Select patient --</option>
                        @foreach (var p in Model.Patients)
                        { <option value="@p.Id">@p.FullName</option> }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Insurance Provider</label>
                    <input asp-for="InsuranceProvider" class="form-control" placeholder="Optional" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Coverage Amount (UGX)</label>
                    <input asp-for="InsuranceCoverage" type="number" step="0.01" class="form-control" />
                </div>
            </div>

            <div class="form-section-title">Billing Items</div>
            <div id="itemList" class="mb-3"></div>

            <div class="card mb-3" style="background:#f7fafc">
                <div class="card-body">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-5"><label class="form-label">Description</label>
                            <input class="form-control form-control-sm" id="iDesc" placeholder="e.g. Consultation Fee" /></div>
                        <div class="col-md-2"><label class="form-label">Qty</label>
                            <input class="form-control form-control-sm" id="iQty" type="number" value="1" min="1" /></div>
                        <div class="col-md-2"><label class="form-label">Unit Price (UGX)</label>
                            <input class="form-control form-control-sm" id="iPrice" type="number" min="50000" max="100000" placeholder="50000 – 100000" /></div>
                        <div class="col-md-3">
                            <button type="button" class="btn btn-primary btn-sm w-100 mt-4" onclick="addItem()">Add Item</button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="totalBox" class="text-end mb-4" style="display:none">
                <span class="text-muted">Subtotal: </span><strong id="subtotalVal"></strong>
                <span class="ms-3 text-muted">+8% Tax: </span><strong id="taxVal"></strong>
                <span class="ms-3 fs-5">Total: </span><strong class="fs-5 text-primary" id="totalVal"></strong>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" onclick="syncItems()">Generate Bill</button>
                <a href="/Billing" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    let items = [];

    function addItem() {
        const desc = document.getElementById('iDesc').value.trim();
        const qty = parseInt(document.getElementById('iQty').value) || 1;
        const price = parseFloat(document.getElementById('iPrice').value) || 0;
        if (!desc) return alert('Description is required.');
        if (price < 50000 || price > 100000) return alert('Unit price must be between UGX 50,000 and UGX 100,000.');
        items.push({ Description: desc, Quantity: qty, UnitPrice: price });
        renderItems();
        document.getElementById('iDesc').value = '';
        document.getElementById('iQty').value = 1;
        document.getElementById('iPrice').value = '';
    }

    function removeItem(i) { items.splice(i, 1); renderItems(); }

    function renderItems() {
        const el = document.getElementById('itemList');
        if (!items.length) { el.innerHTML = '<p class="text-muted small">No items added yet.</p>'; document.getElementById('totalBox').style.display='none'; return; }
        el.innerHTML = `<table class="table table-sm"><thead><tr><th>Description</th><th>Qty</th><th>Unit Price</th><th>Total</th><th></th></tr></thead><tbody>` +
            items.map((it, i) => `<tr><td>${it.Description}</td><td>${it.Quantity}</td><td>UGX ${it.UnitPrice.toFixed(2)}</td><td>UGX ${(it.Quantity*it.UnitPrice).toFixed(2)}</td><td><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeItem(${i})">✕</button></td></tr>`).join('') +
            '</tbody></table>';
        const sub = items.reduce((s,it)=>s+it.Quantity*it.UnitPrice, 0);
        const tax = sub*0.08;
        document.getElementById('subtotalVal').textContent = 'UGX '+sub.toFixed(2);
        document.getElementById('taxVal').textContent = 'UGX '+tax.toFixed(2);
        document.getElementById('totalVal').textContent = 'UGX '+(sub+tax).toFixed(2);
        document.getElementById('totalBox').style.display = 'block';
    }

    function syncItems() { document.getElementById('itemsJson').value = JSON.stringify(items); }
    renderItems();
</script>
}
