@page
@model HospitalWeb.Pages.Doctors.CreateModel
@{ ViewData["Title"] = "Add Doctor"; ViewData["Page"] = "Doctors"; }

<div class="page-header">
    <h2><i class="fa-solid fa-user-plus me-2"></i>Add New Doctor</h2>
    <a href="/Doctors" class="btn btn-outline-secondary btn-sm">← Back</a>
</div>

<div class="card" style="max-width:700px">
    <div class="card-body">
        <form method="post">
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">First Name *</label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Last Name *</label>
                    <input asp-for="LastName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Specialization</label>
                    <select asp-for="Specialization" asp-items="Html.GetEnumSelectList<HospitalManagement.Core.Models.Specialization>()" class="form-select"></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Consultation Fee (UGX)</label>
                    <input asp-for="ConsultationFee" type="number" min="50000" max="100000" class="form-control" placeholder="50000 – 100000" />
                    <small class="text-muted">Must be between UGX 50,000 and UGX 100,000</small>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Phone *</label>
                    <input asp-for="PhoneNumber" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">License Number *</label>
                    <input asp-for="LicenseNumber" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">Available Days</label>
                    <div class="d-flex flex-wrap gap-3 mt-1">
                        @foreach (DayOfWeek day in Enum.GetValues<DayOfWeek>())
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="AvailableDayInts" value="@((int)day)" id="day_@day"
                                       @(day != DayOfWeek.Saturday && day != DayOfWeek.Sunday ? "checked" : "") />
                                <label class="form-check-label" for="day_@day">@day</label>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Add Doctor</button>
                <a href="/Doctors" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
