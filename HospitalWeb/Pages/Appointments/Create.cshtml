@page
@model HospitalWeb.Pages.Appointments.CreateModel
@{ ViewData["Title"] = "Schedule Appointment"; ViewData["Page"] = "Appointments"; }

<div class="page-header">
    <h2><i class="fa-solid fa-calendar-plus me-2"></i>Schedule Appointment</h2>
    <a href="/Appointments" class="btn btn-outline-secondary btn-sm">← Back</a>
</div>

@if (Model.ErrorMessage != null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="card" style="max-width:640px">
    <div class="card-body">
        <form method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Patient *</label>
                    <select asp-for="PatientId" class="form-select">
                        <option value="0">-- Select patient --</option>
                        @foreach (var p in Model.Patients)
                        { <option value="@p.Id">@p.FullName</option> }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Doctor *</label>
                    <select asp-for="DoctorId" class="form-select">
                        <option value="0">-- Select doctor --</option>
                        @foreach (var d in Model.Doctors)
                        { <option value="@d.Id">@d.FullName – @d.Specialization</option> }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Date & Time *</label>
                    <input asp-for="AppointmentDate" type="datetime-local" class="form-control" />
                    <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label class="form-label">Reason for Visit *</label>
                    <input asp-for="Reason" class="form-control" />
                    <span asp-validation-for="Reason" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Schedule Appointment</button>
                <a href="/Appointments" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
