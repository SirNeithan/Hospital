@page
@model HospitalWeb.Pages.Records.IndexModel
@{ ViewData["Title"] = "Medical Records"; ViewData["Page"] = "Records"; }

<div class="page-header">
    <h2><i class="fa-solid fa-file-medical me-2"></i>Medical Records</h2>
    <a href="/Records/Create" class="btn btn-primary">+ New Record</a>
</div>

<div class="card">
    <div class="card-header">
        <form method="get" class="d-flex gap-2" style="flex:1">
            <input type="text" name="Search" value="@Model.Search" class="form-control"
                   placeholder="Search patient, doctor or diagnosis…" style="max-width:340px" />
            <button class="btn btn-outline-primary btn-sm">Search</button>
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <a href="/Records" class="btn btn-outline-secondary btn-sm">Clear</a>
            }
        </form>
        <small class="text-muted">@Model.Records.TotalCount record(s)</small>
    </div>
    <div class="card-body p-0">
        @if (!Model.Records.Items.Any())
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="fa-solid fa-file-medical"></i></div>
                <p>No records found</p>
            </div>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr><th>ID</th><th>Date</th><th>Patient</th><th>Doctor</th><th>Diagnosis</th><th>Prescriptions</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Records.Items)
                    {
                        <tr>
                            <td><span class="text-muted">#@r.Id</span></td>
                            <td><small>@r.RecordDate.ToString("MMM dd, yyyy")</small></td>
                            <td class="fw-semibold">@r.PatientName</td>
                            <td><small class="text-muted">@r.DoctorName</small></td>
                            <td>@r.Diagnosis</td>
                            <td><span class="badge bg-light text-dark border">@r.Prescriptions.Count Rx</span></td>
                            <td><a href="/Records/Details?id=@r.Id" class="btn btn-sm btn-outline-secondary">View</a></td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="px-3 border-top">
                @await Component.InvokeAsync("Pagination", new { result = Model.Records })
            </div>
        }
    </div>
</div>
