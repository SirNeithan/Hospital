@using HospitalWeb.Models
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – HMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

<!-- Sidebar -->
<aside class="sidebar">
    <div class="sidebar-brand">
        <div class="brand-icon"><i class="fa-solid fa-hospital"></i></div>
        <h4>City Hospital</h4>
        <small>Management System</small>
    </div>
    <nav>
        @if (User.IsInRole("Admin"))
        {
            <div class="nav-section">Main</div>
            <a href="/" class="@(ViewData["Page"]?.ToString() == "Dashboard" ? "active" : "")">
                <span class="nav-icon"><i class="fa-solid fa-chart-line"></i></span> Dashboard
            </a>
            <div class="nav-section">Management</div>
            <a href="/Patients" class="@(ViewData["Page"]?.ToString()?.StartsWith("Patients") == true ? "active" : "")">
                <span class="nav-icon"><i class="fa-solid fa-users"></i></span> Patients
            </a>
            <a href="/Doctors" class="@(ViewData["Page"]?.ToString()?.StartsWith("Doctors") == true ? "active" : "")">
                <span class="nav-icon"><i class="fa-solid fa-user-doctor"></i></span> Doctors
            </a>
            <a href="/Appointments" class="@(ViewData["Page"]?.ToString()?.StartsWith("Appointments") == true ? "active" : "")">
                <span class="nav-icon"><i class="fa-solid fa-calendar-check"></i></span> Appointments
            </a>
            <a href="/Records" class="@(ViewData["Page"]?.ToString()?.StartsWith("Records") == true ? "active" : "")">
                <span class="nav-icon"><i class="fa-solid fa-file-medical"></i></span> Medical Records
            </a>
            <div class="nav-section">Operations</div>
            <a href="/Billing" class="@(ViewData["Page"]?.ToString()?.StartsWith("Billing") == true ? "active" : "")">
                <span class="nav-icon"><i class="fa-solid fa-file-invoice-dollar"></i></span> Billing
            </a>
            <a href="/Rooms" class="@(ViewData["Page"]?.ToString()?.StartsWith("Rooms") == true ? "active" : "")">
                <span class="nav-icon"><i class="fa-solid fa-bed"></i></span> Rooms & Wards
            </a>
            <div class="nav-section">System</div>
            <a href="/Admin/Users" class="@(ViewData["Page"]?.ToString() == "Admin" ? "active" : "")">
                <span class="nav-icon"><i class="fa-solid fa-users-gear"></i></span> User Management
            </a>
        }
        else
        {
            <div class="nav-section">Patient Portal</div>
            <a href="/Dashboard/Index" class="@(ViewData["Page"]?.ToString() == "PatientDashboard" ? "active" : "")">
                <span class="nav-icon"><i class="fa-solid fa-house-medical"></i></span> My Dashboard
            </a>
            <a href="/Dashboard/BookAppointment" class="@(ViewData["Page"]?.ToString() == "BookAppointment" ? "active" : "")">
                <span class="nav-icon"><i class="fa-solid fa-calendar-plus"></i></span> Book Appointment
            </a>
            <a href="/Dashboard/Doctors" class="@(ViewData["Page"]?.ToString() == "OurDoctors" ? "active" : "")">
                <span class="nav-icon"><i class="fa-solid fa-user-doctor"></i></span> Our Doctors
            </a>
            <a href="/Dashboard/MyRecords" class="@(ViewData["Page"]?.ToString() == "MyRecords" ? "active" : "")">
                <span class="nav-icon"><i class="fa-solid fa-file-medical"></i></span> My Records
            </a>
            <a href="/Dashboard/MyBills" class="@(ViewData["Page"]?.ToString() == "MyBills" ? "active" : "")">
                <span class="nav-icon"><i class="fa-solid fa-file-invoice-dollar"></i></span> My Bills
            </a>
            <a href="/Dashboard/Profile" class="@(ViewData["Page"]?.ToString() == "Profile" ? "active" : "")">
                <span class="nav-icon"><i class="fa-solid fa-user-pen"></i></span> My Profile
            </a>
        }
    </nav>
    <div class="sidebar-footer">
        &copy; @DateTime.Now.Year City Hospital
    </div>
</aside>

<!-- Main -->
<div class="main-content">
    <header class="topbar">
        <span class="topbar-title">@ViewData["Title"]</span>
        <div class="topbar-right d-flex align-items-center gap-3">
            <span class="topbar-date d-none d-md-inline">@DateTime.Now.ToString("dddd, MMM dd yyyy")</span>
            @if (User.Identity?.IsAuthenticated == true)
            {
                var fullName = User.FindFirst("FullName")?.Value ?? User.Identity.Name ?? "";
                var initials = fullName.Contains(' ')
                    ? $"{fullName.Split(' ')[0][0]}{fullName.Split(' ')[1][0]}"
                    : fullName.Length > 1 ? fullName[..2].ToUpper() : "?";
                <div class="d-flex align-items-center gap-2">
                    <span class="avatar" title="@fullName">@initials</span>
                    <span class="d-none d-lg-inline" style="font-size:.875rem">@fullName</span>
                    <a href="/Auth/Logout" class="btn btn-sm btn-outline-secondary ms-1" title="Logout">
                        <i class="fa-solid fa-right-from-bracket"></i>
                    </a>
                </div>
            }
            else
            {
                <a href="/Auth/Login" class="btn btn-sm btn-primary">Login</a>
            }
        </div>
    </header>

    @if (TempData["Success"] != null)
    {
        <div class="mx-4 mt-3">
            <div class="alert alert-success alert-dismissible fade show mb-0">
                <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <main class="page-body">
        @RenderBody()
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
