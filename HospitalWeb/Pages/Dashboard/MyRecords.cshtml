@page
@model HospitalWeb.Pages.Dashboard.MyRecordsModel
@{ ViewData["Title"] = "My Medical Records"; ViewData["Page"] = "PatientDashboard"; }

<div class="page-header">
    <h2><i class="fa-solid fa-file-medical me-2"></i>My Medical Records</h2>
    <a href="/Dashboard/Index" class="btn btn-outline-secondary">← Dashboard</a>
</div>

@if (!Model.Records.Any())
{
    <div class="card">
        <div class="empty-state">
            <div class="empty-icon"><i class="fa-solid fa-file-circle-xmark"></i></div>
            <p>No medical records yet.</p>
        </div>
    </div>
}
else
{
    @foreach (var r in Model.Records)
    {
        <div class="card mb-3">
            <div class="card-header">
                <div>
                    <h6 class="mb-0 fw-bold">@r.Diagnosis</h6>
                    <small class="text-muted">@r.RecordDate.ToString("MMMM dd, yyyy") &nbsp;•&nbsp; @r.DoctorName</small>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @if (!string.IsNullOrEmpty(r.Symptoms))
                    {
                        <div class="col-md-6">
                            <div class="fw-semibold text-muted" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.5px">Symptoms</div>
                            <p class="mb-0">@r.Symptoms</p>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(r.TreatmentPlan))
                    {
                        <div class="col-md-6">
                            <div class="fw-semibold text-muted" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.5px">Treatment Plan</div>
                            <p class="mb-0">@r.TreatmentPlan</p>
                        </div>
                    }
                    @if (r.Prescriptions.Any())
                    {
                        <div class="col-12">
                            <div class="fw-semibold text-muted mb-2" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.5px">Prescriptions</div>
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered mb-0">
                                    <thead class="table-light">
                                        <tr><th>Medicine</th><th>Dosage</th><th>Frequency</th><th>Duration</th><th>Instructions</th></tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var p in r.Prescriptions)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@p.MedicineName</td>
                                            <td>@p.Dosage</td>
                                            <td>@p.Frequency</td>
                                            <td>@p.DurationDays days</td>
                                            <td><small class="text-muted">@p.Instructions</small></td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(r.Notes))
                    {
                        <div class="col-12">
                            <div class="fw-semibold text-muted" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.5px">Notes</div>
                            <p class="mb-0 text-muted">@r.Notes</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}
