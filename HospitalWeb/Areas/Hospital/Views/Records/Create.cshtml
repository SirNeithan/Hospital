@model RecordFormViewModel
@{ ViewData["Title"] = "New Medical Record"; ViewData["Page"] = "Records"; }

<div class="page-header">
    <h2><i class="fa-solid fa-file-medical me-2"></i>New Medical Record</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Patient *</label>
                    <select name="PatientId" class="form-select">
                        <option value="0">— Select patient —</option>
                        @foreach (var p in Model.Patients)
                        { <option value="@p.Id" selected="@(Model.PatientId == p.Id)">@p.FullName</option> }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Doctor *</label>
                    <select name="DoctorId" class="form-select">
                        <option value="0">— Select doctor —</option>
                        @foreach (var d in Model.Doctors)
                        { <option value="@d.Id">@d.FullName — @d.Specialization</option> }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Appointment (optional)</label>
                    <select name="AppointmentId" class="form-select">
                        <option value="0">— None —</option>
                        @foreach (var a in Model.Appointments)
                        { <option value="@a.Id">@a.AppointmentDate.ToString("MMM dd") — @a.PatientName</option> }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Diagnosis" class="form-label fw-semibold">Diagnosis *</label>
                    <input asp-for="Diagnosis" class="form-control" />
                    <span asp-validation-for="Diagnosis" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Symptoms" class="form-label fw-semibold">Symptoms *</label>
                    <input asp-for="Symptoms" class="form-control" />
                    <span asp-validation-for="Symptoms" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="TreatmentPlan" class="form-label fw-semibold">Treatment Plan *</label>
                    <textarea asp-for="TreatmentPlan" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="TreatmentPlan" class="text-danger small"></span>
                </div>
                <div class="col-md-6"><label asp-for="LabResults" class="form-label fw-semibold">Lab Results</label><textarea asp-for="LabResults" class="form-control" rows="2"></textarea></div>
                <div class="col-md-6"><label asp-for="Allergies" class="form-label fw-semibold">Allergies</label><input asp-for="Allergies" class="form-control" /></div>
                <div class="col-12"><label asp-for="Notes" class="form-label fw-semibold">Notes</label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
            </div>

            <h6 class="fw-bold mb-3">Prescriptions</h6>
            <div id="rx-container">
                <div class="row g-2 mb-2 rx-row">
                    <div class="col-md-2"><input type="text" class="form-control rx-med" placeholder="Medicine" /></div>
                    <div class="col-md-2"><input type="text" class="form-control rx-dose" placeholder="Dosage" /></div>
                    <div class="col-md-2"><input type="text" class="form-control rx-freq" placeholder="Frequency" /></div>
                    <div class="col-md-2"><input type="number" class="form-control rx-dur" placeholder="Days" min="1" /></div>
                    <div class="col-md-3"><input type="text" class="form-control rx-inst" placeholder="Instructions" /></div>
                    <div class="col-md-1"><button type="button" class="btn btn-outline-danger w-100 remove-rx">✕</button></div>
                </div>
            </div>
            <button type="button" id="add-rx" class="btn btn-outline-secondary btn-sm mt-2">+ Add Prescription</button>
            <input type="hidden" asp-for="PrescriptionsJson" id="prescJson" />

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary" onclick="buildRxJson()">Save Record</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('add-rx').addEventListener('click', () => {
    const row = document.querySelector('.rx-row').cloneNode(true);
    row.querySelectorAll('input').forEach(i => i.value = '');
    document.getElementById('rx-container').appendChild(row);
});
document.getElementById('rx-container').addEventListener('click', e => {
    if (e.target.classList.contains('remove-rx') &&
        document.querySelectorAll('.rx-row').length > 1) e.target.closest('.rx-row').remove();
});
function buildRxJson() {
    const items = [];
    document.querySelectorAll('.rx-row').forEach(row => {
        const med = row.querySelector('.rx-med').value.trim();
        if (med) items.push({
            MedicineName: med,
            Dosage:       row.querySelector('.rx-dose').value,
            Frequency:    row.querySelector('.rx-freq').value,
            DurationDays: parseInt(row.querySelector('.rx-dur').value) || 0,
            Instructions: row.querySelector('.rx-inst').value
        });
    });
    document.getElementById('prescJson').value = JSON.stringify(items);
}
</script>
}
