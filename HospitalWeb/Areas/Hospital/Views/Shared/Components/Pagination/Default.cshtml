@model HospitalWeb.ViewComponents.PaginationViewModel

@if (Model.TotalPages <= 1 && Model.TotalCount == 0)
{
    return;
}

<div class="d-flex justify-content-between align-items-center px-1 py-2">
    <small class="text-muted">
        @if (Model.TotalCount == 0)
        {
            <span>No results</span>
        }
        else
        {
            <span>Showing <strong>@Model.From</strong>–<strong>@Model.To</strong> of <strong>@Model.TotalCount</strong></span>
        }
    </small>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0">

                @* Previous *@
                <li class="page-item @(!Model.HasPrev ? "disabled" : "")">
                    <a class="page-link" href="@(Model.HasPrev ? Model.BuildUrl(Model.PageNumber - 1) : "#")" aria-label="Previous">
                        <i class="fa-solid fa-chevron-left" style="font-size:.7rem"></i>
                    </a>
                </li>

                @* Page number window (5 pages around current) *@
                @{
                    int start = Math.Max(1, Model.PageNumber - 2);
                    int end   = Math.Min(Model.TotalPages, start + 4);
                    start     = Math.Max(1, end - 4);
                }

                @if (start > 1)
                {
                    <li class="page-item"><a class="page-link" href="@Model.BuildUrl(1)">1</a></li>
                    @if (start > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                }

                @for (int p = start; p <= end; p++)
                {
                    <li class="page-item @(p == Model.PageNumber ? "active" : "")">
                        <a class="page-link" href="@Model.BuildUrl(p)">@p</a>
                    </li>
                }

                @if (end < Model.TotalPages)
                {
                    @if (end < Model.TotalPages - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                    <li class="page-item"><a class="page-link" href="@Model.BuildUrl(Model.TotalPages)">@Model.TotalPages</a></li>
                }

                @* Next *@
                <li class="page-item @(!Model.HasNext ? "disabled" : "")">
                    <a class="page-link" href="@(Model.HasNext ? Model.BuildUrl(Model.PageNumber + 1) : "#")" aria-label="Next">
                        <i class="fa-solid fa-chevron-right" style="font-size:.7rem"></i>
                    </a>
                </li>

            </ul>
        </nav>
    }
</div>
