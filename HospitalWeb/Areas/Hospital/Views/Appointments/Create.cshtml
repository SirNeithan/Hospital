@model AppointmentFormViewModel
@{ ViewData["Title"] = "Schedule Appointment"; ViewData["Page"] = "Appointments"; }

<div class="page-header">
    <h2><i class="fa-solid fa-calendar-plus me-2"></i>Schedule Appointment</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{ <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation me-2"></i>@Model.ErrorMessage</div> }

<div class="card" style="max-width:640px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="PatientId" class="form-label fw-semibold">Patient *</label>
                <select asp-for="PatientId" class="form-select">
                    <option value="0">— Select patient —</option>
                    @foreach (var p in Model.Patients)
                    { <option value="@p.Id" selected="@(Model.PatientId == p.Id)">@p.FullName</option> }
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="DoctorId" class="form-label fw-semibold">Doctor *</label>
                <select asp-for="DoctorId" class="form-select">
                    <option value="0">— Select doctor —</option>
                    @foreach (var d in Model.Doctors)
                    { <option value="@d.Id">@d.FullName — @d.Specialization</option> }
                </select>
                <span asp-validation-for="DoctorId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="AppointmentDate" class="form-label fw-semibold">Date & Time *</label>
                <input asp-for="AppointmentDate" type="datetime-local" class="form-control"
                       value="@Model.AppointmentDate.ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="AppointmentDate" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Reason" class="form-label fw-semibold">Reason *</label>
                <input asp-for="Reason" class="form-control" placeholder="e.g. Routine check-up…" />
                <span asp-validation-for="Reason" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Notes" class="form-label fw-semibold">Notes</label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Schedule</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
