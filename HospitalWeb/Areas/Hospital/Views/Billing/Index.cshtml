@model BillingListViewModel
@{ ViewData["Title"] = "Billing"; ViewData["Page"] = "Billing"; }

<div class="page-header">
    <h2><i class="fa-solid fa-file-invoice-dollar me-2"></i>Billing & Payments</h2>
    <a asp-action="Create" class="btn btn-primary">+ Generate Bill</a>
</div>

<div class="stat-grid mb-4" style="grid-template-columns:repeat(3,1fr)">
    <div class="stat-card"><div class="stat-icon green"><i class="fa-solid fa-sack-dollar"></i></div><div class="stat-info"><div class="stat-value">UGX @Model.TotalRevenue.ToString("N0")</div><div class="stat-label">Total Collected</div></div></div>
    <div class="stat-card"><div class="stat-icon yellow"><i class="fa-solid fa-clock-rotate-left"></i></div><div class="stat-info"><div class="stat-value">UGX @Model.Outstanding.ToString("N0")</div><div class="stat-label">Outstanding</div></div></div>
    <div class="stat-card"><div class="stat-icon blue"><i class="fa-solid fa-receipt"></i></div><div class="stat-info"><div class="stat-value">@Model.Bills.TotalCount</div><div class="stat-label">@(Model.Filter == "unpaid" ? "Unpaid Bills" : "Total Bills")</div></div></div>
</div>

<div class="d-flex gap-2 mb-3">
    <a asp-action="Index" asp-route-filter="all"    class="btn btn-sm @(Model.Filter == "all"    ? "btn-primary" : "btn-outline-secondary")">All Bills</a>
    <a asp-action="Index" asp-route-filter="unpaid" class="btn btn-sm @(Model.Filter == "unpaid" ? "btn-primary" : "btn-outline-secondary")">Unpaid</a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Bills.Items.Any())
        { <div class="empty-state"><div class="empty-icon"><i class="fa-solid fa-receipt"></i></div><p>No bills found</p></div> }
        else
        {
            <table class="table">
                <thead><tr><th>ID</th><th>Patient</th><th>Date</th><th>Total</th><th>Paid</th><th>Balance</th><th>Status</th><th></th></tr></thead>
                <tbody>
                @foreach (var b in Model.Bills.Items)
                {
                    <tr>
                        <td><span class="text-muted">#@b.Id</span></td>
                        <td class="fw-semibold">@b.PatientName</td>
                        <td><small>@b.BillDate.ToString("MMM dd, yyyy")</small></td>
                        <td>UGX @b.TotalAmount.ToString("N2")</td>
                        <td class="text-success">UGX @b.AmountPaid.ToString("N2")</td>
                        <td class="@(b.Balance > 0 ? "text-warning fw-semibold" : "text-success")">UGX @b.Balance.ToString("N2")</td>
                        <td><span class="badge @(b.Status == BillStatus.Paid ? "bg-success text-white" : b.Status == BillStatus.Overdue ? "bg-danger text-white" : b.Status == BillStatus.PartiallyPaid ? "bg-warning text-dark" : "bg-light text-dark border")">@b.Status</span></td>
                        <td class="d-flex gap-1">
                            <a asp-action="Details" asp-route-id="@b.Id" class="btn btn-sm btn-outline-secondary">View</a>
                            @if (b.Status != BillStatus.Paid && b.Status != BillStatus.Cancelled)
                            { <a asp-action="Pay" asp-route-id="@b.Id" class="btn btn-sm btn-outline-success">Pay</a> }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            <div class="px-3 border-top">
                @await Component.InvokeAsync("Pagination", new { result = Model.Bills })
            </div>
        }
    </div>
</div>
