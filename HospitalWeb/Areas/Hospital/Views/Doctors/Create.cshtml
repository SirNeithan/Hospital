@model DoctorFormViewModel
@{ ViewData["Title"] = "Add Doctor"; ViewData["Page"] = "Doctors"; }

<div class="page-header">
    <h2><i class="fa-solid fa-user-doctor me-2"></i>Add Doctor</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
</div>

<div class="card" style="max-width:760px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row g-3">
                <div class="col-md-4"><label asp-for="FirstName" class="form-label fw-semibold">First Name *</label><input asp-for="FirstName" class="form-control" /><span asp-validation-for="FirstName" class="text-danger small"></span></div>
                <div class="col-md-4"><label asp-for="LastName" class="form-label fw-semibold">Last Name *</label><input asp-for="LastName" class="form-control" /><span asp-validation-for="LastName" class="text-danger small"></span></div>
                <div class="col-md-4"><label asp-for="Specialization" class="form-label fw-semibold">Specialization</label><select asp-for="Specialization" asp-items="Html.GetEnumSelectList<Specialization>()" class="form-select"></select></div>
                <div class="col-md-4"><label asp-for="PhoneNumber" class="form-label fw-semibold">Phone *</label><input asp-for="PhoneNumber" class="form-control" /><span asp-validation-for="PhoneNumber" class="text-danger small"></span></div>
                <div class="col-md-4"><label asp-for="Email" class="form-label fw-semibold">Email</label><input asp-for="Email" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="LicenseNumber" class="form-label fw-semibold">License Number *</label><input asp-for="LicenseNumber" class="form-control" /><span asp-validation-for="LicenseNumber" class="text-danger small"></span></div>
                <div class="col-md-4"><label asp-for="ConsultationFee" class="form-label fw-semibold">Consultation Fee (UGX)</label><input asp-for="ConsultationFee" type="number" class="form-control" /></div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Available Days</label>
                    <div class="d-flex gap-3 flex-wrap">
                        @foreach (DayOfWeek day in Enum.GetValues<DayOfWeek>())
                        {
                            <div class="form-check">
                                <input type="checkbox" name="AvailableDayInts" value="@((int)day)" class="form-check-input" id="day@day" />
                                <label class="form-check-label" for="day@day">@day</label>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Add Doctor</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
