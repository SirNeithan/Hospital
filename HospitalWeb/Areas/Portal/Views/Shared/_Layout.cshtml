@using HospitalManagement.Core.Models
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – HMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<aside class="sidebar">
    <div class="sidebar-brand">
        <div class="brand-icon"><i class="fa-solid fa-hospital"></i></div>
        <h4>City Hospital</h4>
        <small>Patient Portal</small>
    </div>
    <nav>
        <div class="nav-section">Patient Portal</div>
        <a asp-area="Portal" asp-controller="Dashboard" asp-action="Index"
           class="@(ViewData["Page"]?.ToString() == "PatientDashboard" ? "active" : "")">
            <span class="nav-icon"><i class="fa-solid fa-house-medical"></i></span> My Dashboard
        </a>
        <a asp-area="Portal" asp-controller="Dashboard" asp-action="BookAppointment"
           class="@(ViewData["Page"]?.ToString() == "BookAppointment" ? "active" : "")">
            <span class="nav-icon"><i class="fa-solid fa-calendar-plus"></i></span> Book Appointment
        </a>
        <a asp-area="Portal" asp-controller="Dashboard" asp-action="Doctors"
           class="@(ViewData["Page"]?.ToString() == "OurDoctors" ? "active" : "")">
            <span class="nav-icon"><i class="fa-solid fa-user-doctor"></i></span> Our Doctors
        </a>
        <a asp-area="Portal" asp-controller="Dashboard" asp-action="MyRecords"
           class="@(ViewData["Page"]?.ToString() == "MyRecords" ? "active" : "")">
            <span class="nav-icon"><i class="fa-solid fa-file-medical"></i></span> My Records
        </a>
        <a asp-area="Portal" asp-controller="Dashboard" asp-action="MyBills"
           class="@(ViewData["Page"]?.ToString() == "MyBills" ? "active" : "")">
            <span class="nav-icon"><i class="fa-solid fa-file-invoice-dollar"></i></span> My Bills
        </a>
        <a asp-area="Portal" asp-controller="Dashboard" asp-action="Profile"
           class="@(ViewData["Page"]?.ToString() == "Profile" ? "active" : "")">
            <span class="nav-icon"><i class="fa-solid fa-user-pen"></i></span> My Profile
        </a>
    </nav>
    <div class="sidebar-footer">&copy; @DateTime.Now.Year City Hospital</div>
</aside>

<div class="main-content">
    <header class="topbar">
        <span class="topbar-title">@ViewData["Title"]</span>
        <div class="topbar-right d-flex align-items-center gap-3">
            <span class="topbar-date d-none d-md-inline">@DateTime.Now.ToString("dddd, MMM dd yyyy")</span>
            @if (User.Identity?.IsAuthenticated == true)
            {
                var fullName = User.FindFirst("FullName")?.Value ?? User.Identity.Name ?? "";
                var initials = fullName.Contains(' ')
                    ? $"{fullName.Split(' ')[0][0]}{fullName.Split(' ')[1][0]}"
                    : fullName.Length > 1 ? fullName[..2].ToUpper() : "?";
                <div class="d-flex align-items-center gap-2">
                    <span class="avatar" title="@fullName">@initials</span>
                    <span class="d-none d-lg-inline" style="font-size:.875rem">@fullName</span>
                    <a asp-area="Admin" asp-controller="Auth" asp-action="Logout"
                       class="btn btn-sm btn-outline-secondary ms-1" title="Logout">
                        <i class="fa-solid fa-right-from-bracket"></i>
                    </a>
                </div>
            }
        </div>
    </header>
    @if (TempData["Success"] != null)
    {
        <div class="mx-4 mt-3">
            <div class="alert alert-success alert-dismissible fade show mb-0">
                <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }
    <main class="page-body">@RenderBody()</main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
