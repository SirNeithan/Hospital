@model LoginViewModel
@{ Layout = null; ViewData["Title"] = "Login"; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login – City Hospital</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <style>
        body{background:linear-gradient(135deg,#0f4c81 0%,#1a7a5e 100%);min-height:100vh;display:flex;align-items:center;justify-content:center;font-family:'Segoe UI',sans-serif}
        .auth-card{background:#fff;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,.25);width:100%;max-width:440px;overflow:hidden}
        .auth-header{background:linear-gradient(135deg,#0f4c81,#1a7a5e);padding:2rem;text-align:center;color:#fff}
        .auth-header .hospital-icon{font-size:3rem;margin-bottom:.5rem}
        .auth-header h1{font-size:1.5rem;font-weight:700;margin:0}
        .auth-header p{font-size:.85rem;opacity:.85;margin:.25rem 0 0}
        .auth-body{padding:2rem}
        .form-label{font-weight:600;font-size:.875rem;color:#374151}
        .form-control{border-radius:8px;border:1.5px solid #d1d5db;padding:.6rem 1rem}
        .form-control:focus{border-color:#0f4c81;box-shadow:0 0 0 3px rgba(15,76,129,.15)}
        .input-group-text{border-radius:8px 0 0 8px;background:#f3f4f6;border:1.5px solid #d1d5db;color:#6b7280}
        .btn-login{background:linear-gradient(135deg,#0f4c81,#1a7a5e);border:none;border-radius:8px;padding:.75rem;font-weight:600;color:#fff;width:100%}
        .btn-login:hover{opacity:.9;color:#fff}
        .alert-error{background:#fef2f2;border:1px solid #fecaca;color:#dc2626;border-radius:8px;padding:.75rem 1rem;font-size:.875rem}
        .register-link{text-align:center;font-size:.875rem;color:#6b7280}
        .register-link a{color:#0f4c81;font-weight:600;text-decoration:none}
    </style>
</head>
<body>
<div class="auth-card">
    <div class="auth-header">
        <div class="hospital-icon"><i class="fa-solid fa-hospital"></i></div>
        <h1>City Hospital HMS</h1>
        <p>Hospital Management System</p>
    </div>
    <div class="auth-body">
        <h5 class="fw-bold mb-1">Welcome back</h5>
        <p class="text-muted mb-3" style="font-size:.875rem">Sign in to your account to continue</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert-error mb-3"><i class="fa-solid fa-circle-exclamation me-2"></i>@Model.ErrorMessage</div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success mb-3"><i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]</div>
        }

        <form asp-controller="Auth" asp-action="Login" method="post">
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            <div class="mb-3">
                <label asp-for="Username" class="form-label">Username</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa-solid fa-user"></i></span>
                    <input asp-for="Username" class="form-control" placeholder="Enter your username" autocomplete="username" />
                </div>
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                    <input asp-for="Password" class="form-control" placeholder="Enter your password" autocomplete="current-password" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                <label asp-for="RememberMe" class="form-check-label" style="font-size:.875rem">Remember me</label>
            </div>
            <button type="submit" class="btn btn-login">
                <i class="fa-solid fa-right-to-bracket me-2"></i>Sign In
            </button>
        </form>
        <div class="text-center mt-3" style="font-size:.875rem;color:#6b7280">
            New patient? <a asp-controller="Auth" asp-action="Register" style="color:#0f4c81;font-weight:600">Create an account</a>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
